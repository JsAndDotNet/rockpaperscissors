@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IAsyncDisposable
@inject NavigationManager NavigationManager

<PageTitle>Rock Paper Scissors Lizard Spock – Lobby</PageTitle>

<div class="lobby-container">
    <div class="lobby-header">
        <h1>Rock Paper Scissors Lizard Spock</h1>
        <p class="subtitle">Real-time multiplayer · Challenge a friend!</p>
    </div>

    <div class="lobby-content">
        <div class="section-header">
            <h2>Open Games</h2>
            <button class="btn-primary" @onclick="ShowCreateModal">＋ New Game</button>
        </div>

        @if (!_connected)
        {
            <div class="empty-state">
                <div class="spinner"></div>
                <p>Connecting…</p>
            </div>
        }
        else if (_games.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon">🎮</div>
                <p>No games yet — create one and wait for a friend!</p>
            </div>
        }
        else
        {
            <div class="games-list">
                @foreach (var game in _games)
                {
                    <div class="game-card">
                        <div class="game-card-info">
                            <span class="creator-name">@game.CreatorName</span>
                            <span class="game-status">@FormatMode(game.Mode) · Waiting for opponent…</span>
                        </div>
                        <button class="btn-join" @onclick="() => ShowJoinModal(game.Id, game.CreatorName)">
                            Join
                        </button>
                    </div>
                }
            </div>
        }
    </div>
</div>

@if (_showModal)
{
    <div class="rps-modal-overlay" @onclick="CloseModal">
        <div class="rps-modal" @onclick:stopPropagation="true">
            <h3>@(_isCreating
                ? _createStep == 1 ? "Create New Game" : "Choose Game Mode"
                : $"Join {_joiningCreator}'s Game")</h3>

            @if (_isCreating && _createStep == 2)
            {
                <div class="mode-choice-grid">
                    <button class="mode-choice-card @(_selectedMode == GameMode.Classic ? "active" : "")"
                            @onclick="() => SelectMode(GameMode.Classic)">
                        <span class="mode-choice-title">Classic</span>
                        <span class="mode-choice-desc">Rock · Paper · Scissors</span>
                    </button>
                    <button class="mode-choice-card @(_selectedMode == GameMode.LizardSpock ? "active" : "")"
                            @onclick="() => SelectMode(GameMode.LizardSpock)">
                        <span class="mode-choice-title">Lizard Spock</span>
                        <span class="mode-choice-desc">Rock · Paper · Scissors · Lizard · Spock</span>
                    </button>
                </div>
            }
            else
            {
                <div class="form-group">
                    <label for="playerNameInput">Your Name</label>
                    <input id="playerNameInput"
                           class="form-input"
                           @bind="_playerName"
                           @bind:event="oninput"
                           @onkeydown="OnNameKeyDown"
                           placeholder="Enter your name"
                           maxlength="20"
                           autofocus />
                </div>
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <p class="error-text">@_errorMessage</p>
                }
            }
            <div class="rps-modal-actions">
                <button class="btn-secondary" @onclick="CloseModal">Cancel</button>
                <button class="btn-primary"
                        @onclick="ConfirmAction"
                        disabled="@(_isCreating ? (_createStep == 1 && string.IsNullOrWhiteSpace(_playerName)) : string.IsNullOrWhiteSpace(_playerName))">
                    @(_isCreating
                        ? _createStep == 1 ? "Next" : "Create"
                        : "Join")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private HubConnection? _hubConnection;
    private List<GameInfo> _games = new();
    private bool _connected;
    private bool _showModal;
    private bool _isCreating;
    private int _createStep = 1;
    private GameMode _selectedMode = GameMode.LizardSpock;
    private string _playerName = "";
    private string _joiningGameId = "";
    private string _joiningCreator = "";
    private string _errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/gamehub"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<List<GameInfo>>("LobbyUpdated", games =>
        {
            _games = games;
            InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
        _connected = true;
        await _hubConnection.InvokeAsync("SubscribeToLobby");
    }

    private void ShowCreateModal()
    {
        _playerName = "";
        _errorMessage = "";
        _isCreating = true;
        _showModal = true;
        _createStep = 1;
        _selectedMode = GameMode.LizardSpock;
    }

    private void ShowJoinModal(string gameId, string creatorName)
    {
        _playerName = "";
        _errorMessage = "";
        _isCreating = false;
        _createStep = 1;
        _joiningGameId = gameId;
        _joiningCreator = creatorName;
        _showModal = true;
    }

    private void CloseModal()
    {
        _showModal = false;
        _createStep = 1;
    }

    private void ConfirmAction()
    {
        if (_isCreating)
        {
            if (_createStep == 1)
            {
                if (string.IsNullOrWhiteSpace(_playerName)) return;
                _createStep = 2;
                return;
            }

            var name = Uri.EscapeDataString(_playerName.Trim());
            var mode = _selectedMode.ToString();
            NavigationManager.NavigateTo($"/game/new?name={name}&mode={mode}");
            return;
        }

        if (string.IsNullOrWhiteSpace(_playerName)) return;
        var joinName = Uri.EscapeDataString(_playerName.Trim());
        NavigationManager.NavigateTo($"/game/{_joiningGameId}?name={joinName}");
    }

    private void OnNameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            ConfirmAction();
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            try { await _hubConnection.InvokeAsync("UnsubscribeFromLobby"); } catch { /* best effort */ }
            await _hubConnection.DisposeAsync();
        }
    }

    private void SelectMode(GameMode mode) => _selectedMode = mode;

    private static string FormatMode(GameMode mode) =>
        mode == GameMode.Classic ? "Classic (RPS)" : "Lizard Spock";
}
